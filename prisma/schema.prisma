generator client {
  provider = "prisma-client"
  output   = "../api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String     @id
  email           String     @unique
  name            String
  passwordHash      String     @map("password_hash")
  passwordChangedAt DateTime?  @map("password_changed_at") @db.Timestamptz(6)
  termsAgreedAt     DateTime?  @map("terms_agreed_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  tasks           Task[]
  categories      Category[]
  tokens          Token[]

  @@map("users")
}

// MCP 等の長期トークン (issueLongLived) 個別失効のためのレコード。
// JWT に jti claim を埋め、verify 時に DB の revokedAt を突き合わせる (issue #37)。
// session トークン (短期) は追跡しない。
model Token {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  scope      String
  jti        String    @unique
  label      String    @default("")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tokens")
}

model Task {
  id        String    @id
  userId    String?   @map("user_id")
  title     String
  status    String    @default("todo")
  priority  String    @default("medium")
  category  String    @default("その他")
  dueDate   DateTime? @map("due_date") @db.Date
  memo      String    @default("")
  pinned    Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Category {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("categories")
}
