# コピーして .env を作成してください（.env は gitignored）
# cp .env.example .env

# Neon の接続文字列（Neon console から取得）
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# JWT 署名用シークレット（32バイト以上の乱数）
# 生成例: openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-value

# MCP サーバー用の長期JWT（任意、MCPを使うときのみ）
# 発行: npx tsx issue-token.ts <your-email>
TASK_APP_TOKEN=
